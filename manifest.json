{
  "manifest_version": 2,
  "name": "SingleKey Code Catcher",
  "version": "1.0",
  "description": "Fångar login-koden från singlekey-id.com Location headers",

  "browser_specific_settings": {
    "gecko": {
      "id": "singlekey-code-catcher@tozzi89.github.com",
      "strict_min_version": "142.0",
      "update_url": "https://raw.githubusercontent.com/Tozzi89/SingleKey-Code-Catcher/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "*://singlekey-id.com/*",
    "*://*.singlekey-id.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html",
    "default_title": "SingleKey Code Catcher",
    "browser_style": false
  }
}
